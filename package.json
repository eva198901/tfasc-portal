{
  "name": "tfasc-portal",
  "description": "TFASC Portal - 標售資料爬蟲任務管理系統 (Nuxt 3 + FastAPI)",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "pnpm run test:unit:coverage && pnpm run test:e2e",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "start:fullstack": "./start-fullstack.sh",
    "start:backend": "cd server && python start.py",
    "test:backend": "cd server && python test_simple.py"
  },
  "dependencies": {
    "@fontsource/noto-sans-tc": "^5.0.17",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@nuxt/eslint": "^0.7.2",
    "@pinia/nuxt": "^0.5.1",
    "axios": "^1.6.5",
    "nuxt": "^3.11.2",
    "pinia": "^3.0.3",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@nuxtjs/tailwindcss": "^6.12.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/typography": "^0.5.16",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "c8": "^10.1.3",
    "eslint": "^9.0.0",
    "happy-dom": "^17.6.3",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.1",
    "wait-on": "^8.0.1"
  }
}
